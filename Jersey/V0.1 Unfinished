		local c=mkCard(sc); pd(c,14,12,14,14); vl(c,10)
		local cs=c:FindFirstChildOfClass("UIStroke")
		-- name
		local nr=frow(c,22); hl(nr,8)
		mkDot(nr,MUT,6,6)
		local nl=mkLabel(nr,accName,13,WHITE,true,7); nl.Size=UDim2.new(1,-18,0,22)
		-- input
		local ti=mkInp(c,"Paste texture ID  (rbxassetid://… or just the number)",7)
		-- btn row
		local br=frow(c,34); hl(br,8)
		local ab=mkBtn(br,"Apply",WHITE,BG,34,7); ab.Size=UDim2.new(0,90,0,34)
		ab.MouseButton1Click:Connect(function()
			local nid=normalizeId(ti.Text)
			if not nid then toast("Paste a valid texture ID","err"); return end
			ab.Text="⏳"; ab.BackgroundColor3=CARD2
			task.spawn(function()
				local char=player.Character
				if not char then toast("No character","err"); flashERR(ab); return end
				local acc=char:FindFirstChild(accName)
				if not acc then toast(accName.." not on character","err"); flashERR(ab); return end
				pcall(function() ContentProvider:PreloadAsync({nid}) end)
				local ok=applyTexture(acc,nid)
				if ok then flashOK(ab,cs); toast("Applied to "..accName,"ok")
				else flashERR(ab); toast("Apply failed","err") end
			end)
		end)
	end
end

------------------------------------------------------------------------
-- GROUP TAB  — three panels stacked in the scroll:
--   1. Group selector (create + pill chooser)
--   2. Jersey texture table (inline edit → auto-push on save)
--   3. Players panel (server list picker + member roster)
------------------------------------------------------------------------
rebuildGroup=function()
	local sc=tabScrolls["Group"]; clearKids(sc)

	--------------------------------------------------------------------
	-- PANEL 1 — GROUP SELECTOR
	--------------------------------------------------------------------
	local gCard=mkCard(sc); pd(gCard,14,12,14,14); vl(gCard,10)

	-- header row
	local ghRow=frow(gCard,18); hl(ghRow,8)
	mkDot(ghRow,WHITE,5,7)
	mkLabel(ghRow,"GROUPS",9,DIM,true,7).Size=UDim2.new(1,-14,0,18)

	-- create row
	local createRow=frow(gCard,34); hl(createRow,8)
	local nameInp=mkInp(createRow,"New group name…",7); nameInp.Size=UDim2.new(1,-110,0,34)
	local createBtn=mkBtn(createRow,"＋  Create",WHITE,BG,34,7); createBtn.Size=UDim2.new(0,102,0,34)

	createBtn.MouseButton1Click:Connect(function()
		local name=nameInp.Text:match("^%s*(.-)%s*$")
		if name=="" then toast("Enter a group name","err"); return end
		for _,g in ipairs(groups) do if g.name==name then toast("'"..name.."' already exists","err"); return end end
		table.insert(groups,{name=name,slots={},players={}})
		nameInp.Text=""; toast("Group '"..name.."' created","ok")
		rebuildGroup(); updateStatus()
	end)

	if #groups>0 then
		local pillRow=frow(gCard); hl(pillRow,6)
		for gi,grp in ipairs(groups) do
			local isActive=(activeGroupIdx==gi)
			local pb=Instance.new("TextButton",pillRow)
			pb.Size=UDim2.new(0,0,0,28); pb.AutomaticSize=Enum.AutomaticSize.X
			pb.BackgroundColor3=isActive and WHITE or CARD2
			pb.Text="  "..(isActive and "⚡ " or "")..grp.name.."  "
			pb.TextColor3=isActive and BG or DIM; pb.Font=Enum.Font.GothamBold; pb.TextSize=11
			pb.BorderSizePixel=0; pb.ZIndex=7; cr(pb,99)
			if not isActive then sk(pb,BDR) end
			pb.MouseButton1Click:Connect(function()
				doActivateGroup(gi); toast("'"..grp.name.."' activated","ok")
				rebuildGroup(); updateStatus()
			end)
		end
		mkWrap(gCard,"Tap a group pill to activate it. Jersey changes below push to all members instantly.",9,MUT).ZIndex=6
	else
		mkWrap(gCard,"Create your first group above, then add jersey textures and players below.",10,MUT).ZIndex=6
	end

	local ag=activeGroup()
	if not ag then
		local nc=mkCard(sc); pd(nc,16,14,16,14); vl(nc,5)
		mkLabel(nc,"No group active",12,DIM,true).ZIndex=7
		mkWrap(nc,"Create a group and tap it to activate. Then set jersey textures below — they auto-push to all group members.",10,MUT).ZIndex=7
		return
	end

	--------------------------------------------------------------------
	-- PANEL 2 — JERSEY TEXTURE TABLE (inline editable)
	--------------------------------------------------------------------
	local jCard=mkCard(sc); pd(jCard,14,12,14,14); vl(jCard,10)

	-- section header
	local jhRow=frow(jCard,24); hl(jhRow,8)
	mkDot(jhRow,GRN,8,7)
	local jhl=mkLabel(jhRow,ag.name.."  ·  Jersey Textures",12,GRN,true,7); jhl.Size=UDim2.new(1,-130,0,24)
	local pushAllSmall=mkSBtn(jhRow,"▶ Push All",CARD2,DIM,100,26,7); sk(pushAllSmall,BDR)
	pushAllSmall.MouseButton1Click:Connect(function() pushToAll(); toast("Pushed all jerseys to group","ok") end)

	if #detectedJerseys==0 then
		mkLabel(jCard,"No jerseys detected — press ↺ Scan first.",11,DIM).ZIndex=7
	else
		-- Column headers
		local colHdr=frow(jCard,18); hl(colHdr,0); pd(colHdr,2,0,2,0)
		local ch1=mkLabel(colHdr,"JERSEY",8,MUT,true,7); ch1.Size=UDim2.new(0.42,0,1,0)
		local ch2=mkLabel(colHdr,"TEXTURE ID",8,MUT,true,7); ch2.Size=UDim2.new(1,-0.42*W+0,1,0)

		-- one editable row per detected jersey
		local tableBox=fbox(jCard,Color3.fromRGB(11,11,17)); tableBox.AutomaticSize=Enum.AutomaticSize.Y
		cr(tableBox,8); sk(tableBox,BDR); pd(tableBox,0,4,0,4); vl(tableBox,0)

		for ri,accName in ipairs(detectedJerseys) do
			if ri>1 then mkDiv(tableBox) end

			local savedTex=ag.slots[accName]
			local rRow=fbox(tableBox,Color3.fromRGB(11,11,17),50); rRow.AutomaticSize=Enum.AutomaticSize.None
			pd(rRow,10,0,8,0); hl(rRow,0)

			-- jersey name cell
			local nameCell=frow(rRow,50); nameCell.Size=UDim2.new(0.38,0,1,0)
			nameCell.AutomaticSize=Enum.AutomaticSize.None; hl(nameCell,7)
			mkDot(nameCell,savedTex and GRN or MUT,6,7)
			local nl=mkLabel(nameCell,accName,11,savedTex and OFF or DIM,savedTex,7)
			nl.Size=UDim2.new(1,-16,1,0)

			-- texture input cell (fills remaining width)
			local texCell=frow(rRow,50); texCell.Size=UDim2.new(0.62,-80,1,0)
			texCell.AutomaticSize=Enum.AutomaticSize.None; hl(texCell,0)
			local ti2=Instance.new("TextBox",texCell)
			ti2.Size=UDim2.new(1,0,0,34); ti2.BackgroundColor3=INPBG
			ti2.PlaceholderText=savedTex or "Paste texture ID…"
			ti2.PlaceholderColor3=savedTex and Color3.fromRGB(55,70,55) or MUT
			ti2.Text=savedTex or ""; ti2.TextColor3=savedTex and GRNhi or OFF
			ti2.Font=Enum.Font.Code; ti2.TextSize=10; ti2.ClearTextOnFocus=false
			ti2.TextXAlignment=Enum.TextXAlignment.Left; ti2.BorderSizePixel=0; ti2.ZIndex=7
			cr(ti2,6); pd(ti2,8,0,8,0); sk(ti2,BDR)
			ti2.Focused:Connect(function() TweenService:Create(ti2:FindFirstChildOfClass("UIStroke"),TweenInfo.new(0.12),{Color=BDRHI}):Play() end)
			ti2.FocusLost:Connect(function() TweenService:Create(ti2:FindFirstChildOfClass("UIStroke"),TweenInfo.new(0.12),{Color=BDR}):Play() end)

			-- save button
			local saveCell=frow(rRow,50); saveCell.Size=UDim2.new(0,72,1,0)
			saveCell.AutomaticSize=Enum.AutomaticSize.None; pd(saveCell,6,0,0,0); hl(saveCell,0)
			local saveBtn=mkBtn(saveCell,"Save",WHITE,BG,28,7); saveBtn.Size=UDim2.new(1,0,0,28)
			local saveSk=saveBtn:FindFirstChildOfClass("UIStroke") or sk(saveBtn,BDR,0)

			saveBtn.MouseButton1Click:Connect(function()
				local nid=normalizeId(ti2.Text)
				if not nid then
					-- also accept current text as-is if it looks like an ID
					nid=ti2.Text:match("^%s*(.-)%s*$")
					nid=normalizeId(nid)
				end
				if not nid then toast("Invalid texture ID","err"); return end
				saveBtn.Text="⏳"; saveBtn.BackgroundColor3=CARD2
				task.spawn(function()
					ag.slots[accName]=nid
					pcall(function() ContentProvider:PreloadAsync({nid}) end)
					local pushed=0
					for _,username in ipairs(ag.players) do
						for _,rp in ipairs(Players:GetPlayers()) do
							if rp.Name:lower()==username:lower() then
								local char=rp.Character
								if char then
									local acc=char:FindFirstChild(accName)
									if acc then applyTexture(acc,nid); pushed+=1 end
								end
							end
						end
					end
					-- update cell visually
					ti2.Text=nid; ti2.TextColor3=GRNhi
					ti2.PlaceholderText=nid; ti2.PlaceholderColor3=Color3.fromRGB(55,70,55)
					nl.TextColor3=OFF; nl.Font=Enum.Font.GothamBold
					mkDot(nameCell,GRN,6,7)  -- note: adds extra dot, acceptable
					flashOK(saveBtn,nil,"Save")
					local msg="Saved"
					if pushed>0 then msg=msg.."  ·  pushed to "..pushed.." player"..(pushed==1 and "" or "s") end
					toast(msg,"ok")
				end)
			end)

			-- copy button (if saved)
			if savedTex then
				local cpCell=frow(rRow,50); cpCell.Size=UDim2.new(0,0,1,0); cpCell.AutomaticSize=Enum.AutomaticSize.None
				-- invisible spacer push to right — not needed as hl left aligns; just add copy after save
			end
		end
	end

	--------------------------------------------------------------------
	-- PANEL 3 — PLAYERS
	--------------------------------------------------------------------
	local plrCard=mkCard(sc); pd(plrCard,14,12,14,14); vl(plrCard,10)

	-- header
	local plrHdrRow=frow(plrCard,20); hl(plrHdrRow,8)
	mkDot(plrHdrRow,WHITE,5,7)
	local plrHL=mkLabel(plrHdrRow,"PLAYERS  —  "..ag.name,9,DIM,true,7); plrHL.Size=UDim2.new(1,-120,0,20)
	local onlineCnt=0
	for _,u in ipairs(ag.players) do
		for _,rp in ipairs(Players:GetPlayers()) do if rp.Name:lower()==u:lower() then onlineCnt+=1; break end end
	end
	if #ag.players>0 then
		mkPill(plrHdrRow,onlineCnt.."/"..#ag.players.." online",onlineCnt>0 and GRNBG or CARD2,onlineCnt>0 and GRN or MUT,7)
	end

	-- ADD FROM SERVER LIST
	local serverListHdr=frow(plrCard,16); hl(serverListHdr,6)
	mkDot(serverListHdr,AMBER,5,7)
	mkLabel(serverListHdr,"Add from server",9,Color3.fromRGB(200,160,50),true,7).Size=UDim2.new(1,-14,0,16)

	-- live server player list (tap to add)
	local serverPlayers=Players:GetPlayers()
	if #serverPlayers>0 then
		local serverBox=fbox(plrCard,Color3.fromRGB(11,11,17)); serverBox.AutomaticSize=Enum.AutomaticSize.Y
		cr(serverBox,8); sk(serverBox,BDR); pd(serverBox,0,4,0,4); vl(serverBox,0)

		for si,rp in ipairs(serverPlayers) do
			if si>1 then mkDiv(serverBox) end
			local alreadyIn=false
			for _,u in ipairs(ag.players) do if u:lower()==rp.Name:lower() then alreadyIn=true; break end end

			local sRow=fbox(serverBox,Color3.fromRGB(11,11,17),40)
			sRow.AutomaticSize=Enum.AutomaticSize.None; pd(sRow,10,0,8,0); hl(sRow,0)

			-- green dot (all are online by definition)
			local sd=mkDot(sRow,GRN,7,7); sd.LayoutOrder=1
			spacer(sRow,8,7).LayoutOrder=2

			local snl=Instance.new("TextLabel",sRow)
			snl.Size=UDim2.new(1,-150,1,0); snl.BackgroundTransparency=1
			snl.Text=rp.Name; snl.TextColor3=alreadyIn and DIM or Color3.fromRGB(185,245,200)
			snl.Font=alreadyIn and Enum.Font.Gotham or Enum.Font.GothamBold; snl.TextSize=12
			snl.TextXAlignment=Enum.TextXAlignment.Left; snl.TextTruncate=Enum.TextTruncate.AtEnd
			snl.ZIndex=7; snl.LayoutOrder=3

			if alreadyIn then
				local inPill=mkPill(sRow,"Already in group",CARD2,MUT,7); inPill.LayoutOrder=4
			else
				local addBtn=mkSBtn(sRow,"＋  Add",WHITE,BG,88,26,7); addBtn.LayoutOrder=4
				addBtn.MouseButton1Click:Connect(function()
					for _,u in ipairs(ag.players) do if u:lower()==rp.Name:lower() then toast(rp.Name.." already in group","err"); return end end
					table.insert(ag.players,rp.Name)
					pushToChar(rp)
					toast("Added "..rp.Name.." to "..ag.name,"ok")
					rebuildGroup(); updateStatus()
				end)
			end
		end
	else
		mkLabel(plrCard,"No other players in server — use manual add below.",10,MUT).ZIndex=7
	end

	-- MANUAL ADD
	local manHdr=frow(plrCard,16); hl(manHdr,6)
	mkDot(manHdr,WHITE,5,7)
	mkLabel(manHdr,"Manual add  (not in server)",9,DIM,true,7).Size=UDim2.new(1,-14,0,16)

	local manRow=frow(plrCard,34); hl(manRow,8)
	local manInp=mkInp(manRow,"Roblox username (exact spelling)",7); manInp.Size=UDim2.new(1,-114,0,34)
	local manBtn=mkBtn(manRow,"＋  Add",WHITE,BG,34,7); manBtn.Size=UDim2.new(0,106,0,34)

	manBtn.MouseButton1Click:Connect(function()
		local username=manInp.Text:match("^%s*(.-)%s*$")
		if username=="" then toast("Enter a Roblox username","err"); return end
		for _,u in ipairs(ag.players) do if u:lower()==username:lower() then toast(username.." already in group","err"); return end end
		table.insert(ag.players,username)
		manInp.Text=""
		for _,rp in ipairs(Players:GetPlayers()) do if rp.Name:lower()==username:lower() then pushToChar(rp); break end end
		toast("Added "..username.." to "..ag.name,"ok")
		rebuildGroup(); updateStatus()
	end)

	-- MEMBER ROSTER
	if #ag.players>0 then
		local rosterHdr=frow(plrCard,16); hl(rosterHdr,6)
		mkDot(rosterHdr,WHITE,5,7)
		mkLabel(rosterHdr,"Members  ("..#ag.players..")",9,DIM,true,7).Size=UDim2.new(1,-14,0,16)

		local rosterBox=fbox(plrCard,Color3.fromRGB(11,11,17)); rosterBox.AutomaticSize=Enum.AutomaticSize.Y
		cr(rosterBox,8); sk(rosterBox,BDR); pd(rosterBox,0,4,0,4); vl(rosterBox,0)

		for pi,username in ipairs(ag.players) do
			if pi>1 then mkDiv(rosterBox) end
			local isOnline,onlineRp=false,nil
			for _,rp in ipairs(Players:GetPlayers()) do if rp.Name:lower()==username:lower() then isOnline=true; onlineRp=rp; break end end

			local pRow=fbox(rosterBox,Color3.fromRGB(11,11,17),44)
			pRow.AutomaticSize=Enum.AutomaticSize.None; pd(pRow,10,0,8,0); hl(pRow,0)

			mkDot(pRow,isOnline and GRN or MUT,7,7).LayoutOrder=1
			spacer(pRow,8,7).LayoutOrder=2

			local uTxt=Instance.new("TextLabel",pRow)
			uTxt.Size=UDim2.new(1,-196,1,0); uTxt.BackgroundTransparency=1
			uTxt.Text=username; uTxt.TextColor3=isOnline and Color3.fromRGB(185,245,200) or Color3.fromRGB(145,145,165)
			uTxt.Font=isOnline and Enum.Font.GothamBold or Enum.Font.Gotham; uTxt.TextSize=12
			uTxt.TextXAlignment=Enum.TextXAlignment.Left; uTxt.TextTruncate=Enum.TextTruncate.AtEnd
			uTxt.ZIndex=7; uTxt.LayoutOrder=3

			if isOnline then
				local ob=mkPill(pRow,"Online",GRNBG,GRN,7); ob.LayoutOrder=4
				spacer(pRow,6,7).LayoutOrder=5
			end

			local pushBtn=mkSBtn(pRow,"▶ Push",CARD2,DIM,68,26,7); sk(pushBtn,BDR); pushBtn.LayoutOrder=6
			pushBtn.MouseButton1Click:Connect(function()
				if not isOnline then toast(username.." not in server","err"); return end
				pushToChar(onlineRp); toast("Pushed to "..username,"ok")
			end)
			spacer(pRow,6,7).LayoutOrder=7

			local remBtn=mkSBtn(pRow,"✕",REDBG,RED,28,26,7); sk(remBtn,Color3.fromRGB(55,18,18)); remBtn.LayoutOrder=8
			remBtn.MouseButton1Click:Connect(function()
				table.remove(ag.players,pi); toast("Removed "..username,"err"); rebuildGroup(); updateStatus()
			end)
		end
	else
		mkWrap(plrCard,"No players in this group yet. Add from the server list above or manually.",10,MUT).ZIndex=7
	end

	-- DELETE GROUP
	local delRow=frow(sc,30); hl(delRow,0,Enum.HorizontalAlignment.Right)
	local delBtn=mkSBtn(delRow,"✕  Delete  '"..ag.name.."'",REDBG,RED,190,28,6); sk(delBtn,Color3.fromRGB(55,18,18))
	delBtn.MouseButton1Click:Connect(function()
		local name=ag.name; table.remove(groups,activeGroupIdx)
		activeGroupIdx=#groups>0 and 1 or nil
		if activeGroupIdx then doActivateGroup(activeGroupIdx) end
		toast("Deleted '"..name.."'","err"); rebuildGroup(); updateStatus()
	end)
end

------------------------------------------------------------------------
-- SCAN
------------------------------------------------------------------------
local function scanJerseys()
	local char=player.Character; detectedJerseys={}
	if not char then toast("No character found","err"); return end
	for _,child in ipairs(char:GetChildren()) do
		if child:IsA("Accessory") and child.Name:sub(1,7)=="JERSEY_" then
			table.insert(detectedJerseys,child.Name)
		end
	end
	table.sort(detectedJerseys)
	local n=#detectedJerseys
	statusTxt.Text=n.." jersey"..(n==1 and "" or "s").." found"
	statusDot.BackgroundColor3=n>0 and GRN or MUT
	toast(n.." jersey"..(n==1 and "" or "s").." found",n>0 and "ok" or nil)
	rebuildMe(); rebuildGroup()
end

------------------------------------------------------------------------
-- WIRE UP
------------------------------------------------------------------------
scanBtn.MouseButton1Click:Connect(scanJerseys)

pushAllBtn.MouseButton1Click:Connect(function()
	if not activeGroupIdx then toast("No active group","err"); return end
	pushToAll(); toast("Pushed all jerseys to group members","ok")
end)

tabBtns["Group"].MouseButton1Click:Connect(function() setTab("Group"); rebuildGroup(); updateStatus() end)
tabBtns["Me"].MouseButton1Click:Connect(function() setTab("Me"); rebuildMe() end)

player.CharacterAdded:Connect(function()
	task.wait(0.7); scanJerseys()
	if activeGroupIdx then
		for _,rp in ipairs(Players:GetPlayers()) do
			if rp.Name==player.Name then pushToChar(rp); break end
		end
	end
end)

if player.Character then scanJerseys() end
rebuildMe(); rebuildGroup(); updateStatus()
setTab("Me")
