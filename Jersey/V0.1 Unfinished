local function normalizeId(raw)
	if not raw or raw == "" then return nil end
	if raw:match("^rbxassetid://%d+$") then return raw end
	local n = raw:match("rbxassetid://(%d+)") or raw:match("[?&]id=(%d+)") or raw:match("^%s*(%d+)%s*$")
	return n and ("rbxassetid://"..n) or nil
end

local function cloneSwapHandle(acc, fn)
	local h = acc:FindFirstChild("Handle"); if not h then return false end
	local nh = h:Clone()
	if not pcall(fn, nh) then nh:Destroy(); return false end
	local cf = h.CFrame
	nh.Anchored = false; h:Destroy(); nh.Parent = acc; nh.CFrame = cf
	local char = acc.Parent
	if char then
		local fa = nh:FindFirstChildOfClass("Attachment")
		if fa then
			for _, d in ipairs(char:GetDescendants()) do
				if d:IsA("Attachment") and d.Name == fa.Name and d.Parent ~= nh then
					local bp = d.Parent
					if bp and bp:IsA("BasePart") then
						local ia = false
						pcall(function() ia = bp.Parent:IsA("Accessory") end)
						if not ia then
							nh.CFrame = d.WorldCFrame * fa.CFrame:Inverse()
							local wc = Instance.new("WeldConstraint")
							wc.Part0 = nh; wc.Part1 = bp; wc.Parent = nh; break
						end
					end
				end
			end
		end
	end
	return true
end

local function applyTexture(acc, texId)
	return cloneSwapHandle(acc, function(h)
		if h:IsA("MeshPart") then h.TextureID = texId
		else
			local sm = h:FindFirstChildOfClass("SpecialMesh")
			if sm then sm.TextureId = texId end
		end
	end)
end

-- groups[i] = { name, slots={[accName]=texId}, players={username,...} }
local detectedJerseys = {}
local groups          = {}
local activeGroupIdx  = nil
local watchConns      = {}
local charConns       = {}
local cooldowns       = {}

local function activeGroup()
	return activeGroupIdx and groups[activeGroupIdx] or nil
end

local function texForPlayer(username, accName)
	local g = activeGroup()
	return g and g.slots[accName] or nil
end

local function pushToChar(rp)
	local char = rp.Character; if not char then return end
	task.spawn(function()
		task.wait(0.12)
		for _, child in ipairs(char:GetChildren()) do
			if child:IsA("Accessory") and child.Name:sub(1,7) == "JERSEY_" then
				local tex = texForPlayer(rp.Name, child.Name)
				if tex then
					local lk = rp.UserId..child.Name
					if not cooldowns[lk] then
						cooldowns[lk] = true
						task.delay(0.5, function() cooldowns[lk] = nil end)
						pcall(function() ContentProvider:PreloadAsync({tex}) end)
						applyTexture(child, tex)
					end
				end
			end
		end
	end)
end

local function pushToAll()
	local ag = activeGroup(); if not ag then return end
	for _, username in ipairs(ag.players) do
		for _, rp in ipairs(Players:GetPlayers()) do
			if rp.Name:lower() == username:lower() then
				pushToChar(rp); break
			end
		end
	end
end

local function watchAcc(rp, acc)
	local key = rp.UserId..acc.Name; if watchConns[key] then return end
	local conns = {}
	local h = acc:FindFirstChild("Handle")
	if h then
		local function recheck()
			local tex = texForPlayer(rp.Name, acc.Name); if not tex then return end
			local lk = rp.UserId..acc.Name
			if not cooldowns[lk] then
				task.spawn(function() task.wait(0.04); applyTexture(acc, tex) end)
			end
		end
		local ok1,c1 = pcall(function()
			return h:GetPropertyChangedSignal("TextureID"):Connect(recheck)
		end)
		if ok1 then table.insert(conns,c1) end
		local sm = h:FindFirstChildOfClass("SpecialMesh")
		if sm then
			local ok2,c2 = pcall(function()
				return sm:GetPropertyChangedSignal("TextureId"):Connect(recheck)
			end)
			if ok2 then table.insert(conns,c2) end
		end
	end
	watchConns[key] = conns
end

local function setupWatch(rp)
	local function onChar(char)
		task.wait(0.18)
		for _, child in ipairs(char:GetChildren()) do
			if child:IsA("Accessory") and child.Name:sub(1,7) == "JERSEY_" then
				watchAcc(rp, child)
			end
		end
		char.ChildAdded:Connect(function(child)
			if child:IsA("Accessory") and child.Name:sub(1,7) == "JERSEY_" then
				task.wait(0.1); watchAcc(rp, child)
				local tex = texForPlayer(rp.Name, child.Name)
				if tex then
					task.spawn(function()
						task.wait(0.14)
						pcall(function() ContentProvider:PreloadAsync({tex}) end)
						applyTexture(child, tex)
					end)
				end
			end
		end)
		pushToChar(rp)
	end
	if rp.Character then onChar(rp.Character) end
	if not charConns[rp.UserId] then charConns[rp.UserId] = {} end
	table.insert(charConns[rp.UserId], rp.CharacterAdded:Connect(onChar))
end

local function doActivateGroup(idx)
	for _, conns in pairs(charConns) do
		for _, c in ipairs(conns) do pcall(function() c:Disconnect() end) end
	end
	for _, conns in pairs(watchConns) do
		for _, c in ipairs(conns) do pcall(function() c:Disconnect() end) end
	end
	charConns = {}; watchConns = {}; activeGroupIdx = idx
	local ag = activeGroup()
	if not ag then return end
	for _, username in ipairs(ag.players) do
		for _, rp in ipairs(Players:GetPlayers()) do
			if rp.Name:lower() == username:lower() then
				setupWatch(rp); break
			end
		end
	end
	Players.PlayerAdded:Connect(function(rp)
		if activeGroupIdx ~= idx then return end
		local ag2 = activeGroup(); if not ag2 then return end
		for _, u in ipairs(ag2.players) do
			if u:lower() == rp.Name:lower() then setupWatch(rp); break end
		end
	end)
	pushToAll()
end

