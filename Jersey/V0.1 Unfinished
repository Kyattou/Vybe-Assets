local function cr(i,r) local c=Instance.new("UICorner",i); c.CornerRadius=UDim.new(0,r or 8); return c end
local function sk(i,c,t) local s=Instance.new("UIStroke",i); s.Color=c or BDR; s.Thickness=t or 1; return s end
local function pd(i,l,t,r,b)
	local p=Instance.new("UIPadding",i)
	p.PaddingLeft=UDim.new(0,l or 0); p.PaddingTop=UDim.new(0,t or 0)
	p.PaddingRight=UDim.new(0,r or 0); p.PaddingBottom=UDim.new(0,b or 0)
end
local function vl(i,g)
	local l=Instance.new("UIListLayout",i); l.FillDirection=Enum.FillDirection.Vertical
	l.SortOrder=Enum.SortOrder.LayoutOrder; l.Padding=UDim.new(0,g or 0)
	l.VerticalAlignment=Enum.VerticalAlignment.Top; return l
end
local function hl(i,g,ha,va)
	local l=Instance.new("UIListLayout",i); l.FillDirection=Enum.FillDirection.Horizontal
	l.SortOrder=Enum.SortOrder.LayoutOrder; l.Padding=UDim.new(0,g or 0)
	l.HorizontalAlignment=ha or Enum.HorizontalAlignment.Left
	l.VerticalAlignment=va or Enum.VerticalAlignment.Center; return l
end

local function frow(parent, fixedH, zi)
	local f=Instance.new("Frame",parent)
	if fixedH then f.Size=UDim2.new(1,0,0,fixedH); f.AutomaticSize=Enum.AutomaticSize.None
	else f.Size=UDim2.new(1,0,0,0); f.AutomaticSize=Enum.AutomaticSize.Y end
	f.BackgroundTransparency=1; f.BorderSizePixel=0; f.ZIndex=zi or 5; return f
end

local function fbox(parent, col, fixedH, zi)
	local f=Instance.new("Frame",parent)
	if fixedH then f.Size=UDim2.new(1,0,0,fixedH); f.AutomaticSize=Enum.AutomaticSize.None
	else f.Size=UDim2.new(1,0,0,0); f.AutomaticSize=Enum.AutomaticSize.Y end
	f.BackgroundColor3=col or CARD; f.BorderSizePixel=0; f.ZIndex=zi or 4; return f
