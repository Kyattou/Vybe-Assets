		if not(b and b.Parent) then return end
		TweenService:Create(b,TweenInfo.new(0.25),{BackgroundColor3=WHITE,TextColor3=BG}):Play()
		if s then TweenService:Create(s,TweenInfo.new(0.25),{Color=BDR}):Play() end
		b.Text=lbl2 or "Apply"
	end)
end

local function flashERR(b,lbl2)
	b.Text="✗"; TweenService:Create(b,TweenInfo.new(0.14),{BackgroundColor3=RED,TextColor3=WHITE}):Play()
