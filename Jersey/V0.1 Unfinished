local function flashOK(b,s,lbl2)
	b.Text="✓"; TweenService:Create(b,TweenInfo.new(0.14),{BackgroundColor3=GRN,TextColor3=BG}):Play()
	if s then TweenService:Create(s,TweenInfo.new(0.14),{Color=GRN}):Play() end
