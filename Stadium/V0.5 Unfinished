	ADD     = Color3.fromRGB(80,220,130),
	REMOVE  = Color3.fromRGB(220,80,80),
	TEXTURE = Color3.fromRGB(120,180,255),
	MESH    = Color3.fromRGB(255,160,70),
	SA      = Color3.fromRGB(200,100,220),
	WELD    = Color3.fromRGB(200,160,255),
	ATTACH  = Color3.fromRGB(80,220,200),
	PROP    = Color3.fromRGB(220,200,110),
}

local function liveTag(inst, prop)
	if prop=="TextureID" or prop=="TextureId" or prop=="Texture" then return "TEXTURE" end
	if prop=="ColorMap" or prop=="NormalMap" or prop=="RoughnessMap" or prop=="MetalnessMap" then return "SA" end
	if prop=="MeshId" or prop=="MeshType" or prop=="Scale" or prop=="MeshSize" then return "MESH" end
	if inst:IsA("WeldConstraint") or inst:IsA("Weld") then return "WELD" end
	if inst:IsA("Attachment") then return "ATTACH" end
	return "PROP"
end

local function liveVal(inst, prop)
	local ok,v=pcall(function() return inst[prop] end)
	if not ok then return "?" end
	local t=typeof(v)
	if t=="Vector3"  then return string.format("(%.2f,%.2f,%.2f)",v.X,v.Y,v.Z) end
	if t=="CFrame"   then local p=v.Position return string.format("P(%.1f,%.1f,%.1f)",p.X,p.Y,p.Z) end
	if t=="Color3"   then return string.format("RGB(%d,%d,%d)",math.round(v.R*255),math.round(v.G*255),math.round(v.B*255)) end
	if t=="EnumItem" then local s=tostring(v) return s:match("%.([^%.]+)$") or s end
	if t=="Instance" then return v.Name end
	return tostring(v)
end

local function livePath(inst)
	local parts={}; local cur=inst; local char=player.Character
	while cur and cur~=char and cur~=game and #parts<6 do
		table.insert(parts,1,cur.Name); cur=cur.Parent
	end
	return table.concat(parts,".")
end

local function rebuildLive()
