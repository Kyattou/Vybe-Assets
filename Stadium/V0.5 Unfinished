	Attachment=Color3.fromRGB(100,210,200), Weld=Color3.fromRGB(220,200,80),
}
local function secColor(key)
	for k,c in pairs(SEC_COLS) do if key:find(k) then return c end end
	return Color3.fromRGB(130,130,180)
end

local function buildInspectorTab(accName, cfg)
	-- banner
	local banner=Instance.new("Frame",scrolls.inspector); banner.Size=UDim2.new(1,-8,0,24)
	banner.BackgroundColor3=Color3.fromRGB(25,25,40); banner.BorderSizePixel=0; banner.ZIndex=4
	Instance.new("UICorner",banner).CornerRadius=UDim.new(0,6)
	Instance.new("UIStroke",banner).Color=C.accent
	makeLbl(banner,10,0,460,24,"◈  "..accName,Color3.fromRGB(200,200,255),11,Enum.Font.GothamBold)

	local sOrder={}; for k in pairs(cfg) do table.insert(sOrder,k) end
	table.sort(sOrder,function(a,b)
		local rank={Accessory=0,Handle=1}
		local ra,rb=rank[a] or 99,rank[b] or 99
		if ra~=rb then return ra<rb end return a<b
	end)

	for _,sk in ipairs(sOrder) do
		local props=cfg[sk]; local sc=secColor(sk)
		local sh=Instance.new("Frame",scrolls.inspector); sh.Size=UDim2.new(1,-8,0,18); sh.BackgroundTransparency=1; sh.ZIndex=4
		local bar=Instance.new("Frame",sh); bar.Size=UDim2.new(0,3,1,0); bar.BackgroundColor3=sc; bar.BorderSizePixel=0; bar.ZIndex=5
		Instance.new("UICorner",bar).CornerRadius=UDim.new(1,0)
		local sl=Instance.new("TextLabel",sh); sl.Size=UDim2.new(1,-12,1,0); sl.Position=UDim2.new(0,10,0,0)
		sl.BackgroundTransparency=1; sl.Text=sk; sl.TextColor3=sc; sl.Font=Enum.Font.GothamBold; sl.TextSize=9
		sl.TextXAlignment=Enum.TextXAlignment.Left; sl.ZIndex=5

		local pOrder={}; for k in pairs(props) do table.insert(pOrder,k) end; table.sort(pOrder)
		for _,pk in ipairs(pOrder) do
			local val=tostring(props[pk])
			local row=Instance.new("Frame",scrolls.inspector); row.Size=UDim2.new(1,-8,0,20)
			row.BackgroundColor3=Color3.fromRGB(16,16,24); row.BorderSizePixel=0; row.ZIndex=4
			Instance.new("UICorner",row).CornerRadius=UDim.new(0,4)
			local kl=Instance.new("TextLabel",row); kl.Size=UDim2.new(0.42,0,1,0); kl.Position=UDim2.new(0,8,0,0)
			kl.BackgroundTransparency=1; kl.Text=pk; kl.TextColor3=Color3.fromRGB(130,130,190)
			kl.TextXAlignment=Enum.TextXAlignment.Left; kl.Font=Enum.Font.Gotham; kl.TextSize=9
			kl.TextTruncate=Enum.TextTruncate.AtEnd; kl.ZIndex=5
			local vb=Instance.new("TextBox",row); vb.Size=UDim2.new(0.57,-8,0,16); vb.Position=UDim2.new(0.43,0,0.5,-8)
			vb.BackgroundTransparency=1; vb.Text=val; vb.Font=Enum.Font.Code; vb.TextSize=9
			vb.ClearTextOnFocus=false; vb.BorderSizePixel=0; vb.ZIndex=5
			vb.TextXAlignment=Enum.TextXAlignment.Left; vb.TextTruncate=Enum.TextTruncate.AtEnd
			if pk:find("Texture") or pk:find("Mesh") or pk:find("Map") or pk:find("Id") then vb.TextColor3=C.code
			elseif val=="true" then vb.TextColor3=Color3.fromRGB(100,220,140)
			elseif val=="false" then vb.TextColor3=Color3.fromRGB(220,100,100)
			elseif val:find("RGB") then vb.TextColor3=Color3.fromRGB(255,200,100)
			else vb.TextColor3=Color3.fromRGB(200,230,180) end
			vb.Focused:Connect(function() vb:ReleaseFocus(); setclipboard(val); toast("⎘ "..pk) end)
		end
	end
	scrolls.inspector.CanvasSize=UDim2.new(0,0,0,layouts.inspector.AbsoluteContentSize.Y+10)
end

