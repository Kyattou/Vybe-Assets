-- =============================================
-- MAIN SCAN
-- =============================================
local allUrls=""
local rawInspect=""

local function getMainTex(acc)
	local h=acc:FindFirstChild("Handle"); if not h then return "No Handle" end
	if h:IsA("MeshPart") and h.TextureID~="" then return h.TextureID end
	local sm=h:FindFirstChildOfClass("SpecialMesh"); if sm and sm.TextureId~="" then return sm.TextureId end
	local d=h:FindFirstChildOfClass("Decal"); if d and d.Texture~="" then return d.Texture end
	return "No Texture"
end

scanAccessories = function(character)
	-- clear all tabs
	for _,t in ipairs(TABS) do
		for _,c in pairs(scrolls[t]:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
		scrolls[t].CanvasSize=UDim2.new(0,0,0,0)
	end

	local accs={}; local urlLines={}; local inspectLines={}
	for _,obj in pairs(character:GetChildren()) do
		if obj:IsA("Accessory") then
			table.insert(accs, obj)
		end
	end
	table.sort(accs, function(a,b) return a.Name<b.Name end)

	for _,acc in ipairs(accs) do
		local slots=deepScan(acc)
		local mainTex=getMainTex(acc)

		-- Textures tab
		buildTextureTab(acc.Name, slots)

		-- Mesh tab
		buildMeshTab(acc.Name, slots)

		-- Replace tab
		buildReplaceTab(acc.Name, slots)

		-- Inspector tab
		local cfg=inspectAccessory(acc)
		buildInspectorTab(acc.Name, cfg)

		-- URL list
		local id=numId(mainTex)
		if id then
			local slug=acc.Name:gsub("%s+","-"):gsub("[^%w%-]","")
			table.insert(urlLines,"create.roblox.com/store/asset/"..id.."/"..slug)
		end

		-- raw inspect dump
		table.insert(inspectLines,"═══ "..acc.Name.." ═══")
		local sk={}; for k in pairs(cfg) do table.insert(sk,k) end; table.sort(sk)
		for _,s in ipairs(sk) do
			table.insert(inspectLines,"  ["..s.."]")
			local pk={}; for k in pairs(cfg[s]) do table.insert(pk,k) end; table.sort(pk)
			for _,p in ipairs(pk) do
				table.insert(inspectLines,string.format("    %-26s %s",p,tostring(cfg[s][p])))
			end
		end
		table.insert(inspectLines,"")
	end

	countLbl.Text=#accs.." accessor"..(#accs==1 and "y" or "ies").." found"
	allUrls=table.concat(urlLines,"\n"); urlBox.Text=allUrls
	rawInspect=table.concat(inspectLines,"\n")
end

copyUrlBtn.MouseButton1Click:Connect(function()
	if allUrls=="" then toast("⚠ No URLs") return end
	setclipboard(allUrls); toast("⎘ URLs copied!", Color3.fromRGB(30,110,50))
end)
copyRawBtn.MouseButton1Click:Connect(function()
	if rawInspect=="" then toast("⚠ No data") return end
	setclipboard(rawInspect); toast("📋 Inspector copied!")
end)

rescanBtn.MouseButton1Click:Connect(function()
	local c=player.Character
	if not c then toast("⚠ No character") return end
	scanAccessories(c); startWatch(c); rebuildOverrideTab(); toast("↺ Rescanned!")
end)

local function onChar(char)
	task.wait(1.2)
	scanAccessories(char)
	startWatch(char)
end

if player.Character then onChar(player.Character) end
-- rebuild override tab when switching to it
tabOverride.MouseButton1Click:Connect(rebuildOverrideTab)

player.CharacterAdded:Connect(onChar)
