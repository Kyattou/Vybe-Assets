	local start=math.max(1,#feedRows-MAX_ROWS+1)
	for i=start,#feedRows do
		local f=feedRows[i]
		local row=Instance.new("Frame",scrolls.live)
		row.Size=UDim2.new(1,-8,0,17)
		row.BackgroundColor3=(i%2==0) and Color3.fromRGB(14,14,22) or Color3.fromRGB(18,18,28)
		row.BorderSizePixel=0; row.ZIndex=4
		Instance.new("UICorner",row).CornerRadius=UDim.new(0,3)

		-- timestamp
		local tl=Instance.new("TextLabel",row); tl.Size=UDim2.new(0,46,1,0); tl.Position=UDim2.new(0,3,0,0)
		tl.BackgroundTransparency=1; tl.Text=f.ts; tl.TextColor3=Color3.fromRGB(55,55,85)
		tl.Font=Enum.Font.Code; tl.TextSize=8; tl.TextXAlignment=Enum.TextXAlignment.Left; tl.ZIndex=5

		-- tag
		local tag=Instance.new("TextLabel",row); tag.Size=UDim2.new(0,50,0,13); tag.Position=UDim2.new(0,50,0.5,-6.5)
		tag.BackgroundColor3=f.col; tag.BackgroundTransparency=0.25; tag.Text=f.tag
		tag.TextColor3=Color3.new(1,1,1); tag.Font=Enum.Font.GothamBold; tag.TextSize=7; tag.ZIndex=5
		Instance.new("UICorner",tag).CornerRadius=UDim.new(0,3)

		-- content
		local info=Instance.new("TextLabel",row); info.Size=UDim2.new(1,-110,1,0); info.Position=UDim2.new(0,105,0,0)
		info.BackgroundTransparency=1; info.Text=f.text; info.TextColor3=f.col
		info.Font=Enum.Font.Code; info.TextSize=8; info.TextXAlignment=Enum.TextXAlignment.Left
		info.TextTruncate=Enum.TextTruncate.AtEnd; info.ZIndex=5

		-- click to copy
		local btn=Instance.new("TextButton",row); btn.Size=UDim2.new(1,0,1,0)
		btn.BackgroundTransparency=1; btn.Text=""; btn.ZIndex=6
		btn.MouseButton1Click:Connect(function()
			setclipboard(f.text); toast("⎘ "..f.text:sub(1,50))
		end)
	end
	scrolls.live.CanvasSize=UDim2.new(0,0,0,layouts.live.AbsoluteContentSize.Y+8)
	-- scroll to bottom
	local cy=layouts.live.AbsoluteContentSize.Y
	local sh=scrolls.live.AbsoluteSize.Y
	if cy>sh then scrolls.live.CanvasPosition=Vector2.new(0,cy-sh+8) end
end

local function pushFeed(tag, text)
	if livePaused then return end
	local col=FEED_TAG_COLORS[tag] or Color3.fromRGB(180,180,180)
	local ts=string.format("[%05.1f]", os.clock()%1000)
	table.insert(feedRows,{tag=tag,text=text,col=col,ts=ts})
	if #feedRows>MAX_ROWS+60 then
		local t={}; for i=#feedRows-MAX_ROWS+1,#feedRows do table.insert(t,feedRows[i]) end; feedRows=t
	end
	if currentTab=="live" then rebuildLive() end
end

liveClearBtn.MouseButton1Click:Connect(function() feedRows={}; rebuildLive(); toast("Feed cleared") end)
