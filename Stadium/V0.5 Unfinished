local SEC_COLS={
	Accessory=Color3.fromRGB(99,102,241), Handle=Color3.fromRGB(60,180,120),
	SpecialMesh=Color3.fromRGB(200,140,60), SurfaceAppearance=Color3.fromRGB(180,80,180),
