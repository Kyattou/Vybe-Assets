local function toast(msg,col)
	local ex=screen:FindFirstChild("_toast"); if ex then ex:Destroy() end
	local t=Instance.new("Frame",screen); t.Name="_toast"; t.Size=UDim2.new(0,340,0,34)
	t.Position=UDim2.new(0.5,-170,1,-56); t.BackgroundColor3=col or Color3.fromRGB(99,102,241)
	t.BorderSizePixel=0; t.ZIndex=20
	Instance.new("UICorner",t).CornerRadius=UDim.new(0,8)
	local tl=Instance.new("TextLabel",t); tl.Size=UDim2.new(1,0,1,0); tl.BackgroundTransparency=1
	tl.Text=msg; tl.TextColor3=Color3.new(1,1,1); tl.Font=Enum.Font.GothamBold; tl.TextSize=12; tl.ZIndex=20
	TweenService:Create(t,TweenInfo.new(0.25),{Position=UDim2.new(0.5,-170,1,-80)}):Play()
	task.delay(2.6,function()
		if t and t.Parent then
			TweenService:Create(t,TweenInfo.new(0.25),{Position=UDim2.new(0.5,-170,1,-48),BackgroundTransparency=1}):Play()
			task.wait(0.3); t:Destroy()
		end
	end)
end

