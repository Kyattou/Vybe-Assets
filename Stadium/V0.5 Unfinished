-- =============================================
-- OVERRIDE ENGINE
-- Each rule locks a specific property on a specific
-- instance to a specific value. ANY time that property
-- changes away from our value (server replication,
-- game scripts, anything), we instantly re-apply.
-- Uses a per-key cooldown to prevent infinite loops.
-- =============================================

-- overrides[n] = { accName, instName, prop, value, enabled, label }
local overrides = {}

-- cooldown set: keys currently being written by US so we don't
-- react to our own writes and loop
local overrideCooldown = {}

-- texture props we care about for auto-reapply on ANY change
local TEXTURE_PROPS = {
	TextureID  = true,
	TextureId  = true,
	Texture    = true,
	ColorMap   = true,
	NormalMap  = true,
	RoughnessMap = true,
	MetalnessMap = true,
	MeshId     = true,
}

local function applyOverride(acc, ov)
	if not ov.enabled then return end
	local handle = acc:FindFirstChild("Handle")
	if not handle then return end

	-- locate target instance
	local target
	if ov.instName == "Handle" then
		target = handle
	else
		target = handle:FindFirstChild(ov.instName)
			or acc:FindFirstChild(ov.instName, true)
	end
	if not target then return end

	-- check current value — skip if already correct
	local curOk, curVal = pcall(function() return tostring(target[ov.prop]) end)
	if curOk and curVal == ov.value then return end

	-- cooldown key prevents our own write from re-triggering
	local lockKey = tostring(target) .. "|" .. ov.prop
	if overrideCooldown[lockKey] then return end
	overrideCooldown[lockKey] = true
	task.delay(0.3, function() overrideCooldown[lockKey] = nil end)

	if target == handle then
		-- Handle is server-owned: must clone-swap
		cloneSwapHandle(acc, function(h)
			h[ov.prop] = ov.value
			-- also apply all OTHER handle-level overrides for this acc
			-- in the same swap so we don't double-swap
			for _, other in ipairs(overrides) do
				if other ~= ov and other.enabled
					and other.accName == ov.accName
					and other.instName == "Handle" then
					pcall(function() h[other.prop] = other.value end)
					local ok2 = tostring(h[other.prop])
					local lk2 = tostring(h) .. "|" .. other.prop
					overrideCooldown[lk2] = true
					task.delay(0.3, function() overrideCooldown[lk2] = nil end)
				end
			end
		end)
	else
		-- child instance (Decal, Texture, SurfaceAppearance…)
		-- after a clone-swap the Handle is client-owned so children are too
		pcall(function() target[ov.prop] = ov.value end)
		-- if that silently failed (server still owns), clone-swap entire handle
		-- and set on the clone
		task.delay(0.05, function()
			local stillWrong = false
			pcall(function()
				-- re-find after potential swap
				local h2 = acc:FindFirstChild("Handle")
				if not h2 then return end
				local t2 = h2:FindFirstChild(ov.instName) or acc:FindFirstChild(ov.instName, true)
				if not t2 then return end
				stillWrong = tostring(t2[ov.prop]) ~= ov.value
			end)
			if stillWrong then
				local lk2 = lockKey .. "_fallback"
				if overrideCooldown[lk2] then return end
				overrideCooldown[lk2] = true
				task.delay(0.3, function() overrideCooldown[lk2] = nil end)
				cloneSwapHandle(acc, function(h)
					local t2 = h:FindFirstChild(ov.instName)
					if t2 then pcall(function() t2[ov.prop] = ov.value end) end
				end)
			end
		end)
	end

	pushFeed("TEXTURE", "⚡ REAPPLY → " .. ov.accName .. "." .. ov.instName .. "." .. ov.prop .. " = " .. ov.value)
end

-- Called whenever ANY texture property changes anywhere on an accessory.
-- Checks all enabled overrides for that accessory and re-fires matching ones.
local function onTexturePropChanged(inst, prop)
	-- walk up to Accessory
	local acc = inst
	while acc and not acc:IsA("Accessory") do acc = acc.Parent end
	if not acc then return end

	local lockKey = tostring(inst) .. "|" .. prop
	if overrideCooldown[lockKey] then return end

	local instName = inst.Name
	local accName  = acc.Name

	for _, ov in ipairs(overrides) do
		if ov.enabled and ov.accName == accName then
			-- exact match: this specific property on this specific instance
			if ov.instName == instName and ov.prop == prop then
				task.spawn(function()
					task.wait(0.05) -- let server settle
					applyOverride(acc, ov)
				end)
			end
		end
	end
end

-- =============================================
-- WATCH INSTANCE (Live feed + auto-reapply)
-- =============================================
local watchedConns = {}

local PROPS_TO_WATCH = {
	MeshPart         = {"TextureID","MeshId","Size","Color","Material","Transparency","Reflectance","CastShadow","Anchored","CanCollide","Massless","RenderFidelity"},
	Part             = {"Size","Color","Material","Transparency","Reflectance","CastShadow","Anchored","CanCollide","Massless"},
	SpecialMesh      = {"TextureId","MeshId","Scale","Offset","MeshType","VertexColor"},
	Decal            = {"Texture","Transparency","Face"},
	Texture          = {"Texture","Transparency","Face","StudsPerTileU","StudsPerTileV"},
	SurfaceAppearance= {"ColorMap","NormalMap","RoughnessMap","MetalnessMap","AlphaMode"},
	Attachment       = {"CFrame"},
	WeldConstraint   = {"Enabled","Part0","Part1"},
	Weld             = {"C0","C1","Part0","Part1","Enabled"},
	Accessory        = {"AccessoryType"},
}
local function propsFor(inst)
	return PROPS_TO_WATCH[inst.ClassName]
		or (inst:IsA("BasePart") and PROPS_TO_WATCH.Part)
		or {}
end

local function watchInst(inst)
	if watchedConns[inst] then return end
	local conns = {}
	local path  = livePath(inst)

	for _, prop in ipairs(propsFor(inst)) do
		local ok, conn = pcall(function()
			return inst:GetPropertyChangedSignal(prop):Connect(function()
				local val = liveVal(inst, prop)
				pushFeed(liveTag(inst, prop), path .. "." .. prop .. " = " .. val)

				-- auto-reapply if this is a texture property
				if TEXTURE_PROPS[prop] then
					onTexturePropChanged(inst, prop)
				end
			end)
		end)
		if ok and conn then table.insert(conns, conn) end
	end

	table.insert(conns, inst.ChildAdded:Connect(function(child)
		pushFeed("ADD", path .. " ← [" .. child.ClassName .. "] " .. child.Name)
		task.wait()
		watchInst(child)
		for _, p in ipairs(propsFor(child)) do
			local v = liveVal(child, p)
			if v ~= "" and v ~= "false" and v ~= "0" and v ~= "?" then
				pushFeed(liveTag(child, p), livePath(child) .. "." .. p .. " = " .. v)
			end
		end
	end))

	table.insert(conns, inst.ChildRemoved:Connect(function(child)
		pushFeed("REMOVE", path .. " ✕ " .. child.Name .. " [" .. child.ClassName .. "]")
		local old = watchedConns[child]
		if old then
			for _, c in ipairs(old) do pcall(function() c:Disconnect() end) end
			watchedConns[child] = nil
		end
	end))

	watchedConns[inst] = conns
end

local function watchAccessory(acc)
	pushFeed("ADD", "══ Accessory: " .. acc.Name .. " ══")
	watchInst(acc)
	for _, d in ipairs(acc:GetDescendants()) do
		watchInst(d)
		for _, p in ipairs(propsFor(d)) do
			local v = liveVal(d, p)
			if v ~= "" and v ~= "false" and v ~= "0" and v ~= "?" then
				pushFeed(liveTag(d, p), livePath(d) .. "." .. p .. " = " .. v)
			end
		end
	end
	-- Fire ALL enabled overrides for this accessory immediately on spawn/detect.
	-- Wait a beat so the server finishes setting its own values first,
	-- then we overwrite them. This is the respawn fix.
	task.spawn(function()
		task.wait(0.15)
		for _, ov in ipairs(overrides) do
			if ov.enabled and ov.accName == acc.Name then
				applyOverride(acc, ov)
				task.wait(0.02) -- stagger multi-rule swaps slightly
			end
		end
	end)
end

local charWatchConns={}

local function startWatch(char)
	for _,c in ipairs(charWatchConns) do pcall(function() c:Disconnect() end) end; charWatchConns={}
	for k,conns in pairs(watchedConns) do
		for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end; watchedConns[k]=nil
	end
	for _,child in ipairs(char:GetChildren()) do
		if child:IsA("Accessory") then watchAccessory(child) end
	end
	table.insert(charWatchConns, char.ChildAdded:Connect(function(child)
		if child:IsA("Accessory") then
			watchAccessory(child)
			task.delay(1.5, function() if player.Character then scanAccessories(player.Character) end end)
		end
	end))
	table.insert(charWatchConns, char.ChildRemoved:Connect(function(child)
		if child:IsA("Accessory") then pushFeed("REMOVE","══ Removed: "..child.Name.." ══") end
	end))
end

