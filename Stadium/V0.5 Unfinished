-- =============================================
-- UTILS
-- =============================================
local function normalizeId(raw)
	if not raw or raw == "" or raw == "(none)" then return nil end
	if raw:match("^rbxassetid://%d+$") then return raw end
	local n = raw:match("rbxassetid://(%d+)") or raw:match("[?&]id=(%d+)") or raw:match("^%s*(%d+)%s*$")
	return n and ("rbxassetid://"..n) or nil
end

local function numId(raw)
	if not raw then return nil end
	return raw:match("rbxassetid://(%d+)") or raw:match("^%s*(%d+)%s*$")
end

local function v3s(v)  return string.format("%.2f, %.2f, %.2f",v.X,v.Y,v.Z) end
local function cfs(c)  local p=c.Position local x,y,z=c:ToEulerAnglesXYZ() return string.format("P(%.1f,%.1f,%.1f) R(%.0f,%.0f,%.0f)",p.X,p.Y,p.Z,math.deg(x),math.deg(y),math.deg(z)) end
local function cols(c) return string.format("RGB(%d,%d,%d)",math.round(c.R*255),math.round(c.G*255),math.round(c.B*255)) end
local function enums(e) local s=tostring(e) return s:match("%.([^%.]+)$") or s end

-- =============================================
-- HANDLE CLONE-SWAP (core engine)
-- Clone the Handle, apply changes on the clone
-- (client-owned), destroy original, parent clone.
-- This is the ONLY reliable way to change visual
-- properties that are server-replicated.
-- =============================================
local function cloneSwapHandle(accessory, mutateFn)
	local handle = accessory:FindFirstChild("Handle")
	if not handle then return false, "No Handle" end

	local newHandle = handle:Clone()
	local ok, err = pcall(mutateFn, newHandle)
	if not ok then
		newHandle:Destroy()
		return false, tostring(err)
	end

	local savedCF = handle.CFrame
	newHandle.Anchored = false
	handle:Destroy()
	newHandle.Parent = accessory
	newHandle.CFrame = savedCF

	-- Re-weld to body
	local char = accessory.Parent
	if char then
		local firstAtt = newHandle:FindFirstChildOfClass("Attachment")
		if firstAtt then
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("Attachment") and desc.Name == firstAtt.Name and desc.Parent ~= newHandle then
					local bp = desc.Parent
					if bp and bp:IsA("BasePart") then
						local isAcc = false
						pcall(function() isAcc = bp.Parent:IsA("Accessory") end)
						if not isAcc then
							newHandle.CFrame = desc.WorldCFrame * firstAtt.CFrame:Inverse()
							local wc = Instance.new("WeldConstraint")
							wc.Part0 = newHandle; wc.Part1 = bp; wc.Parent = newHandle
							break
						end
					end
				end
			end
		end
	end

	return true, newHandle
end

-- =============================================
-- DEEP SCAN — returns slot list for an accessory
-- =============================================
local function deepScan(accessory)
	local slots = {}
	local handle = accessory:FindFirstChild("Handle")
	if not handle then return slots end

	if handle:IsA("MeshPart") then
		table.insert(slots, {
			label = "MeshPart · TextureID",
			kind  = "texture",
			prop  = "TextureID",
			id    = normalizeId(handle.TextureID) or "(none)",
			meshId= normalizeId(handle.MeshId)    or "(none)",
		})
	end

	local sm = handle:FindFirstChildOfClass("SpecialMesh")
	if sm then
		table.insert(slots, {
			label = "SpecialMesh · TextureId",
			kind  = "texture",
			prop  = "TextureId",
			smName= sm.Name,
			id    = normalizeId(sm.TextureId) or "(none)",
			meshId= normalizeId(sm.MeshId)    or "(none)",
		})
	end

	for _, c in ipairs(handle:GetChildren()) do
		if c:IsA("Decal") then
			table.insert(slots, {
				label   = "Decal · "..c.Name.." · "..enums(c.Face),
				kind    = "decal",
				prop    = "Texture",
				childName = c.Name,
				childClass= "Decal",
				face    = tostring(c.Face),
				id      = normalizeId(c.Texture) or "(none)",
			})
		elseif c:IsA("Texture") then
			table.insert(slots, {
				label   = "Texture · "..c.Name.." · "..enums(c.Face),
				kind    = "decal",
				prop    = "Texture",
				childName = c.Name,
				childClass= "Texture",
				face    = tostring(c.Face),
				id      = normalizeId(c.Texture) or "(none)",
			})
		end
	end

	local sa = handle:FindFirstChildOfClass("SurfaceAppearance")
	if sa then
		for _, mp in ipairs({"ColorMap","NormalMap","RoughnessMap","MetalnessMap"}) do
			table.insert(slots, {
				label = "SurfaceAppearance · "..mp,
				kind  = "sa",
				prop  = mp,
				id    = normalizeId(sa[mp]) or "(none)",
			})
		end
	end

	return slots
end

-- =============================================
-- APPLY TEXTURE via clone-swap
-- =============================================
local function applyTextureToSlot(accessory, slot, normId)
	return cloneSwapHandle(accessory, function(h)
		if slot.prop == "TextureID" then
			h.TextureID = normId

		elseif slot.prop == "TextureId" then
			local sm = h:FindFirstChildOfClass("SpecialMesh")
			if not sm then error("No SpecialMesh") end
			sm.TextureId = normId

		elseif slot.kind == "decal" then
			for _, c in ipairs(h:GetChildren()) do
				if c.ClassName == slot.childClass and c.Name == slot.childName then
					c.Texture = normId; break
				end
			end

		elseif slot.kind == "sa" then
			local sa = h:FindFirstChildOfClass("SurfaceAppearance")
			if not sa then error("No SurfaceAppearance") end
			sa[slot.prop] = normId
		end
	end)
end

-- =============================================
-- APPLY MESH via clone-swap
-- Supports: MeshPart.MeshId (via SpecialMesh swap),
--           SpecialMesh.MeshId, full model asset insert
-- =============================================
local function applyMeshToHandle(accessory, meshAssetId, keepTexture)
	-- Strategy: load the asset, find a Part/MeshPart/Accessory inside,
	-- extract geometry, and build a new Handle from it.
	local nId = numId(meshAssetId)
	if not nId then return false, "Invalid mesh asset ID" end

	local ok, model = pcall(function()
		return InsertService:LoadAsset(tonumber(nId))
	end)
	if not ok or not model then
		return false, "LoadAsset failed — asset private or invalid"
	end

	-- Find the best part to use as the new mesh source
	local srcPart = nil
	-- Prefer Accessory Handle
	local srcAcc = model:FindFirstChildOfClass("Accessory") or model:FindFirstChildOfClass("Hat")
	if srcAcc then
		srcPart = srcAcc:FindFirstChild("Handle")
	end
	-- Fallback: first MeshPart or Part with SpecialMesh
	if not srcPart then
		for _, d in ipairs(model:GetDescendants()) do
			if d:IsA("MeshPart") or (d:IsA("Part") and d:FindFirstChildOfClass("SpecialMesh")) then
				srcPart = d; break
			end
		end
	end
	-- Fallback: first BasePart at all
	if not srcPart then
		srcPart = model:FindFirstChildOfClass("BasePart")
		if not srcPart then
			for _, d in ipairs(model:GetDescendants()) do
				if d:IsA("BasePart") then srcPart = d; break end
			end
		end
	end

	if not srcPart then
		model:Destroy()
		return false, "No usable Part found in asset "..nId
	end

	local handle = accessory:FindFirstChild("Handle")
	if not handle then model:Destroy(); return false, "Accessory has no Handle" end

	-- Save current texture if keepTexture
	local savedTex = ""
	if keepTexture then
		if handle:IsA("MeshPart") then savedTex = handle.TextureID
		else
			local sm = handle:FindFirstChildOfClass("SpecialMesh")
			if sm then savedTex = sm.TextureId end
		end
	end

	local ok2, result = cloneSwapHandle(accessory, function(h)
		if srcPart:IsA("MeshPart") then
			-- If source is MeshPart, swap the MeshId and TextureID on the clone
			-- We have to use a SpecialMesh because MeshPart.MeshId is read-only
			-- Remove existing mesh children
			for _, c in ipairs(h:GetChildren()) do
				if c:IsA("SpecialMesh") then c:Destroy() end
			end
			local sm2 = Instance.new("SpecialMesh")
			sm2.MeshType = Enum.MeshType.FileMesh
			sm2.MeshId   = srcPart.MeshId ~= "" and srcPart.MeshId or ("rbxassetid://"..nId)
			sm2.TextureId= keepTexture and savedTex or (srcPart.TextureID ~= "" and srcPart.TextureID or "")
			sm2.Scale    = Vector3.new(1,1,1)
			sm2.Parent   = h

			-- Copy size
			h.Size = srcPart.Size

		else
			-- Source is a regular Part with SpecialMesh
			local srcSM = srcPart:FindFirstChildOfClass("SpecialMesh")
			for _, c in ipairs(h:GetChildren()) do
				if c:IsA("SpecialMesh") then c:Destroy() end
			end
			if srcSM then
				local newSM = srcSM:Clone()
				if keepTexture and savedTex ~= "" then
					newSM.TextureId = savedTex
				end
				newSM.Parent = h
			end
			h.Size = srcPart.Size
		end
	end)

	model:Destroy()
	return ok2, result
end

-- =============================================
-- FULL ACCESSORY REPLACE (InsertService)
-- =============================================
local function snapAccessory(acc)
	local s = {name=acc.Name}
	pcall(function() s.accType = acc.AccessoryType end)
	local h = acc:FindFirstChild("Handle")
	if not h then return s end
	s.size=h.Size; s.cf=h.CFrame; s.massless=h.Massless
	s.canCollide=h.CanCollide; s.castShadow=h.CastShadow
	s.atts={}
	for _,c in ipairs(h:GetChildren()) do
		if c:IsA("Attachment") then table.insert(s.atts,{name=c.Name,cf=c.CFrame}) end
	end
	return s
end

local function findBodyPart(char, attName)
	if not attName then return char:FindFirstChild("HumanoidRootPart"), nil end
	for _,d in ipairs(char:GetDescendants()) do
		if d:IsA("Attachment") and d.Name==attName then
			local p=d.Parent
			if p and p:IsA("BasePart") then
				local ia=false; pcall(function() ia=p.Parent:IsA("Accessory") end)
				if not ia then return p,d end
			end
		end
	end
	return char:FindFirstChild("HumanoidRootPart"),nil
end

local function fullReplace(accName, normId, onDone)
	local char = player.Character
	if not char then onDone(false,"No character") return end
	local orig = char:FindFirstChild(accName)
	if not orig or not orig:IsA("Accessory") then onDone(false,"Not found — rescan") return end
	local snap = snapAccessory(orig)
	local nid  = numId(normId)
	if not nid then onDone(false,"Bad ID") return end
	task.spawn(function()
		local ok,mdl = pcall(function() return InsertService:LoadAsset(tonumber(nid)) end)
		if not ok or not mdl then onDone(false,"LoadAsset failed") return end
		local newAcc = mdl:FindFirstChildOfClass("Accessory") or mdl:FindFirstChildOfClass("Hat")
		if not newAcc then
			for _,d in ipairs(mdl:GetDescendants()) do
				if d:IsA("Accessory") or d:IsA("Hat") then newAcc=d break end
			end
		end
		if not newAcc then mdl:Destroy(); onDone(false,"No Accessory in asset") return end
		newAcc = newAcc:Clone(); mdl:Destroy()
		local nh = newAcc:FindFirstChild("Handle")
		if not nh then onDone(false,"No Handle in new acc") return end
		pcall(function() nh.Size=snap.size end)
		pcall(function() nh.Massless=snap.massless end)
		pcall(function() nh.CanCollide=snap.canCollide end)
		pcall(function() nh.CastShadow=snap.castShadow end)
		for _,a in ipairs(snap.atts) do
			local na=nh:FindFirstChild(a.name)
			if na and na:IsA("Attachment") then pcall(function() na.CFrame=a.cf end)
			else local att=Instance.new("Attachment"); att.Name=a.name; att.CFrame=a.cf; att.Parent=nh end
		end
		if snap.accType then pcall(function() newAcc.AccessoryType=snap.accType end) end
		newAcc.Name=snap.name
		pcall(function() nh.CFrame=snap.cf end)
		orig:Destroy(); newAcc.Parent=char
		task.wait()
		local hasW=false
		for _,c in ipairs(nh:GetChildren()) do
			if c:IsA("Weld") or c:IsA("WeldConstraint") then hasW=true break end
		end
		if not hasW and #snap.atts>0 then
			local bp,ba = findBodyPart(char, snap.atts[1].name)
			if bp then
				if ba then pcall(function() nh.CFrame=ba.WorldCFrame*snap.atts[1].cf:Inverse() end) end
				local wc=Instance.new("WeldConstraint"); wc.Part0=nh; wc.Part1=bp; wc.Parent=nh
			end
		end
		onDone(true,newAcc)
	end)
end

-- =============================================
-- INSPECTOR DATA
-- =============================================
local function inspectAccessory(acc)
	local d={} local h=acc:FindFirstChild("Handle")
	d["Accessory"]={Name=acc.Name,ClassName=acc.ClassName}
	pcall(function() d["Accessory"].AccessoryType=enums(acc.AccessoryType) end)
	if not h then d["Handle"]={Error="No Handle"} return d end
	d["Handle"]={ClassName=h.ClassName,Size=v3s(h.Size),CFrame=cfs(h.CFrame),
		Color=cols(h.Color),Material=enums(h.Material),
		Transparency=tostring(h.Transparency),Reflectance=tostring(h.Reflectance),
		Anchored=tostring(h.Anchored),CanCollide=tostring(h.CanCollide),
		Massless=tostring(h.Massless),CastShadow=tostring(h.CastShadow)}
	if h:IsA("MeshPart") then
		d["Handle"].MeshId=h.MeshId~="" and h.MeshId or "(none)"
		d["Handle"].TextureID=h.TextureID~="" and h.TextureID or "(none)"
		d["Handle"].MeshSize=v3s(h.MeshSize)
		d["Handle"].RenderFidelity=enums(h.RenderFidelity)
	end
	local sm=h:FindFirstChildOfClass("SpecialMesh")
	if sm then d["SpecialMesh"]={MeshType=enums(sm.MeshType),MeshId=sm.MeshId~="" and sm.MeshId or "(none)",TextureId=sm.TextureId~="" and sm.TextureId or "(none)",Scale=v3s(sm.Scale),Offset=v3s(sm.Offset)} end
	local di,ti=1,1
	for _,c in ipairs(h:GetChildren()) do
		if c:IsA("Decal") then d["Decal#"..di.."_"..c.Name]={Texture=c.Texture~="" and c.Texture or "(none)",Face=enums(c.Face),Transparency=tostring(c.Transparency)} di+=1
		elseif c:IsA("Texture") then d["Texture#"..ti.."_"..c.Name]={Texture=c.Texture~="" and c.Texture or "(none)",Face=enums(c.Face),StudsU=tostring(c.StudsPerTileU),StudsV=tostring(c.StudsPerTileV)} ti+=1 end
	end
	local ai,wi=1,1
	for _,c in ipairs(h:GetChildren()) do
		if c:IsA("Attachment") then d["Attachment#"..ai]={Name=c.Name,CFrame=cfs(c.CFrame)} ai+=1
		elseif c:IsA("WeldConstraint") or c:IsA("Weld") then
			local w={Name=c.Name,Enabled=tostring(c.Enabled)}
			pcall(function() w.Part0=c.Part0 and c.Part0.Name or "nil"; w.Part1=c.Part1 and c.Part1.Name or "nil" end)
			if c:IsA("Weld") then w.C0=cfs(c.C0); w.C1=cfs(c.C1) end
			d[c.ClassName.."#"..wi]=w; wi+=1
		end
	end
	local sa=h:FindFirstChildOfClass("SurfaceAppearance")
	if sa then d["SurfaceAppearance"]={ColorMap=sa.ColorMap~="" and sa.ColorMap or "(none)",NormalMap=sa.NormalMap~="" and sa.NormalMap or "(none)",RoughnessMap=sa.RoughnessMap~="" and sa.RoughnessMap or "(none)",MetalnessMap=sa.MetalnessMap~="" and sa.MetalnessMap or "(none)",AlphaMode=enums(sa.AlphaMode)} end
	return d
end

