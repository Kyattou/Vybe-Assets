	part.Material=Enum.Material.SmoothPlastic
	if shape=="Cylinder" then part.Shape=Enum.PartType.Cylinder
	elseif shape=="Sphere" then part.Shape=Enum.PartType.Ball end

	-- place near player or center
	local char=player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		local hrp=char.HumanoidRootPart; part.CFrame=hrp.CFrame*CFrame.new(0,4,-8+propPartCount*0.5)
	else part.Position=Vector3.new(propPartCount*5,5,0) end
	part.Parent=workspace

	local sp={part=part, name=part.Name}
	table.insert(propParts,sp)

	local lb=G("TextButton",{Size=UDim2.new(1,0,0,30),BackgroundColor3=C.bg2,Text=part.Name,TextColor3=C.off,Font=Enum.Font.GothamBold,TextSize=10,BorderSizePixel=0,AutoButtonColor=false,ZIndex=6},propPartsList)
	corner(6,lb); stroke(lb,C.bdr,1); padding(lb,8,0,0,0); sp.listBtn=lb
	lb.MouseButton1Click:Connect(function() selectedProp=sp; rebuildPropInspector() end)
	lb.MouseEnter:Connect(function() tw(lb,{BackgroundColor3=C.hover},TF) end)
	lb.MouseLeave:Connect(function() tw(lb,{BackgroundColor3=C.bg2},TF) end)
	selectedProp=sp; rebuildPropInspector()
	setStatus("Added "..part.Name.." to workspace",C.green)
end

