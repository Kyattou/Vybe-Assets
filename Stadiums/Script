local function desCF(cf)
	if cf.Components then local c=cf.Components; return CFrame.new(c[1],c[2],c[3],c[4],c[5],c[6],c[7],c[8],c[9],c[10],c[11],c[12]) end
	local p,r,u,l=cf.Position,cf.Right,cf.Up,cf.Look
	return CFrame.new(p[1],p[2],p[3],r[1],u[1],l[1],r[2],u[2],l[2],r[3],u[3],l[3])
end

local function serCF(cf)
	local x,y,z,a,b,c2,d,e,f,g,h,i=cf:GetComponents()
	return {Components={x,y,z,a,b,c2,d,e,f,g,h,i}}
end

local function bounds(parts)
	if #parts==0 then return nil end
	local mn=Vector3.new(math.huge,math.huge,math.huge)
	local mx=Vector3.new(-math.huge,-math.huge,-math.huge)
	for _,p in ipairs(parts) do
		local pos,sz=p.Position,p.Size
		mn=Vector3.new(math.min(mn.X,pos.X-sz.X/2),math.min(mn.Y,pos.Y-sz.Y/2),math.min(mn.Z,pos.Z-sz.Z/2))
		mx=Vector3.new(math.max(mx.X,pos.X+sz.X/2),math.max(mx.Y,pos.Y+sz.Y/2),math.max(mx.Z,pos.Z+sz.Z/2))
	end
	return {Min=mn,Max=mx,Size=mx-mn,Center=(mn+mx)/2}
end

local function fieldGeo()
	local function fp(n) for _,o in ipairs(workspace:GetDescendants()) do if o:IsA("BasePart") and o.Name==n then return o end end end
	local N,S=fp("NorthEndzone"),fp("SouthEndzone")
	if N and S then
		local nP,sP=N.Position,S.Position; local v=nP-sP
		return {length=v.Magnitude,width=math.max(N.Size.X,N.Size.Z,S.Size.X,S.Size.Z),center=Vector3.new((nP.X+sP.X)/2,0,(nP.Z+sP.Z)/2),direction=v.Unit,floorY=(nP.Y+sP.Y)/2}
	end
	local field=workspace:FindFirstChild("Field")
	if not field then for _,o in ipairs(workspace:GetDescendants()) do if o.Name=="Field" and (o:IsA("Model") or o:IsA("BasePart")) then field=o;break end end end
	if field then
		local fpts={}; if field:IsA("BasePart") then table.insert(fpts,field) else for _,o in ipairs(field:GetDescendants()) do if o:IsA("BasePart") then table.insert(fpts,o) end end end
		if #fpts>0 then local b=bounds(fpts); if b then
			local sX,sZ=b.Size.X,b.Size.Z; local fLen,fWid,fDir
			if sZ>=sX then fLen=sZ;fWid=sX;fDir=Vector3.new(0,0,1) else fLen=sX;fWid=sZ;fDir=Vector3.new(1,0,0) end
			return {length=fLen,width=fWid,center=Vector3.new(b.Center.X,0,b.Center.Z),direction=fDir,floorY=b.Min.Y}
		end end
	end
	local flY=0; local bp=workspace:FindFirstChild("Baseplate")
	if bp and bp:IsA("BasePart") then flY=bp.Position.Y+bp.Size.Y/2 end
	return {length=FIELD_LEN_FB,width=FIELD_WID_FB,center=Vector3.new(0,0,0),direction=Vector3.new(0,0,1),floorY=flY}
end

local function groundY(geo, excFolder)
	local excl={}
	if excFolder then for _,o in ipairs(excFolder:GetDescendants()) do if o:IsA("BasePart") then table.insert(excl,o) end end end
	local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Exclude; rp.FilterDescendantsInstances=excl; rp.IgnoreWater=true
	local ori=Vector3.new(geo.center.X,500,geo.center.Z); local dir=Vector3.new(0,-1000,0); local cur=ori
	for _=1,50 do
		local res=workspace:Raycast(cur,dir,rp); if not res then break end
		local hp=res.Instance; local nl=hp.Name:lower()
		local isHelper=nl:find("invisible") or nl:find("collision") or nl:find("hitbox") or nl:find("barrier")
		local isNotImp=true; if excFolder then local c=hp; while c do if c==excFolder then isNotImp=false;break end; c=c.Parent end end
		if hp.Transparency<0.8 and isNotImp and not isHelper then return res.Position.Y end
		table.insert(excl,hp); rp.FilterDescendantsInstances=excl; cur=res.Position+Vector3.new(0,-0.1,0)
	end
	return geo.floorY
end

local function autoFit(allParts, geo, folder)
	local b=bounds(allParts); if not b then return false end
	local szX,szZ=b.Size.X,b.Size.Z; local bestA,bestSc=0,math.huge
	for _,a in ipairs({0,math.pi/2,math.pi,math.pi*1.5}) do
		local c2,s2=math.abs(math.cos(a)),math.abs(math.sin(a))
		local sc=math.abs(szX*c2+szZ*s2-geo.length)+math.abs(szX*s2+szZ*c2-geo.width)
		if sc<bestSc then bestSc=sc;bestA=a end
	end
	local fA=math.atan2(geo.direction.X,geo.direction.Z); local finA=fA+bestA
	local c3,s3=math.abs(math.cos(bestA)),math.abs(math.sin(bestA))
	local eL=szX*c3+szZ*s3; local eW=szX*s3+szZ*c3
	local scale=(geo.length*3.20/eL)*0.65+(geo.width*3.00/eW)*0.35
	local pivX,pivZ=b.Center.X,b.Center.Z; local botY2=b.Min.Y
	local rotCF=CFrame.Angles(0,finA,0); local gY=groundY(geo,folder)
	local origD={}; for _,p in ipairs(allParts) do origD[p]={CFrame=p.CFrame,Size=p.Size} end
	local minVis,minAny=math.huge,math.huge
	for _,p in ipairs(allParts) do
		local o=origD[p]; local relY=(o.CFrame.Position.Y-botY2)*scale; local hH=(o.Size.Y*scale)/2; local wY=gY+relY
		minAny=math.min(minAny,wY-hH); local nl=p.Name:lower()
		if p.Transparency<0.8 and not(nl:find("invisible") or nl:find("collision") or nl:find("hitbox")) then minVis=math.min(minVis,wY-hH) end
	end
	local effMin=minVis<math.huge and minVis or minAny; local yCorr=gY-effMin; local proc=0
	for _,p in ipairs(allParts) do
		local o=origD[p]; local oP=o.CFrame.Position
		local relX=(oP.X-pivX)*scale; local relZ=(oP.Z-pivZ)*scale; local relY=(oP.Y-botY2)*scale
		local rOff=rotCF*Vector3.new(relX,0,relZ)
		p.Size=o.Size*scale; p.CFrame=CFrame.new(geo.center.X+rOff.X,gY+relY+yCorr,geo.center.Z+rOff.Z)*(rotCF*o.CFrame.Rotation)
		proc=proc+1; if proc%100==0 then task.wait() end
	end
	return true
end

local function buildPartFromData(data)
	local part
	local cn=data.ClassName
	if cn=="Part" then part=Instance.new("Part"); if data.Shape then pcall(function() part.Shape=Enum.PartType[data.Shape] end) end
	elseif cn=="WedgePart" then part=Instance.new("WedgePart")
	elseif cn=="CornerWedgePart" then part=Instance.new("CornerWedgePart")
	elseif cn=="MeshPart" then part=Instance.new("MeshPart")
	elseif cn=="TrussPart" then part=Instance.new("TrussPart")
	else part=Instance.new("Part") end
	part.Name=data.Name
	part.Size=Vector3.new(data.Size[1],data.Size[2],data.Size[3])
	part.CFrame=desCF(data.CFrame)
	part.Color=Color3.new(data.Color[1],data.Color[2],data.Color[3])
	if data.BrickColor then pcall(function() part.BrickColor=BrickColor.new(data.BrickColor) end) end
	pcall(function() part.Material=Enum.Material[data.Material] end)
	part.Transparency=data.Transparency or 0; part.Reflectance=data.Reflectance or 0
	part.Anchored=data.Anchored~=nil and data.Anchored or true
	part.CanCollide=data.CanCollide~=nil and data.CanCollide or true
	pcall(function() part.TopSurface=Enum.SurfaceType[data.TopSurface] end)
	pcall(function() part.BottomSurface=Enum.SurfaceType[data.BottomSurface] end)
	if part:IsA("MeshPart") and data.MeshId then part.MeshId=data.MeshId; part.TextureID=data.TextureID or "" end
	if data.Meshes then for _,md in ipairs(data.Meshes) do pcall(function()
		local mesh; if md.ClassName=="SpecialMesh" then mesh=Instance.new("SpecialMesh"); mesh.MeshType=Enum.MeshType[md.MeshType]; mesh.MeshId=md.MeshId; mesh.TextureId=md.TextureId; mesh.Scale=Vector3.new(md.Scale[1],md.Scale[2],md.Scale[3]) end; if mesh then mesh.Name=md.Name;mesh.Parent=part end
	end) end end
	if data.Decals then for _,dd in ipairs(data.Decals) do pcall(function()
		local d=Instance.new(dd.ClassName); d.Name=dd.Name; d.Texture=dd.Texture; d.Face=Enum.NormalId[dd.Face]; d.Transparency=dd.Transparency; d.Parent=part
	end) end end
	if data.SurfaceAppearances then for _,sd in ipairs(data.SurfaceAppearances) do pcall(function()
		local sa=Instance.new("SurfaceAppearance"); sa.Name=sd.Name; pcall(function() sa.AlphaMode=Enum.AlphaMode[sd.AlphaMode] end); sa.ColorMap=sd.ColorMap; sa.MetalnessMap=sd.MetalnessMap; sa.NormalMap=sd.NormalMap; sa.RoughnessMap=sd.RoughnessMap; sa.Parent=part
	end) end end
	if (data.Transparency or 0)>=0.95 or not(data.CanCollide~=nil and data.CanCollide) then
		part.CanCollide=false; part.CanTouch=false; part.CanQuery=false
		pcall(function() part.CollisionGroup="VybeNC" end)
	end
	return part, data.Parent or "Parts", data.FullPath or ""
end

