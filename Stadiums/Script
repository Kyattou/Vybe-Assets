	mp.Parent=moverGui; corner(10,mp); stroke(mp,C.bdr,1)
	makeFrame(mp,UDim2.new(1,0,0,2),UDim2.new(0,0,0,0),C.white,4)

	local function L(text,y,sz,col,bold)
		local l=makeLabel(mp,text,sz or 9,col or C.dim,bold,Enum.TextXAlignment.Left,5)
		l.Size=UDim2.new(1,-24,0,sz and sz+6 or 14); l.Position=UDim2.new(0,12,0,y); return l
	end
	L("POSITION STUDIO",14,14,C.white,true)
	L("WASD · QE rotate · RF elevate",32,10,C.dim)

	local function getAll() local ps={}; if not activeModel or not activeModel.Parent then return ps end
		for _,o in ipairs(activeModel:GetDescendants()) do if o:IsA("BasePart") then table.insert(ps,o) end end; return ps
	end
	local function moveAll(v) for _,p in ipairs(getAll()) do p.CFrame=p.CFrame+v end end
	local function rotAll(deg)
		local ps=getAll(); local b2=bounds(ps); if not b2 then return end
		local pivot=b2.Center; local r=CFrame.Angles(0,math.rad(deg),0)
		local orig={}; for _,p in ipairs(ps) do orig[p]=p.CFrame end
		for _,p in ipairs(ps) do local o=orig[p]; local rel=o.Position-pivot; p.CFrame=CFrame.new(pivot+r*rel)*(r*o.Rotation) end
	end
	local function scaleAll(f)
		local ps=getAll(); local b2=bounds(ps); if not b2 then return end
		local pivot=b2.Center; local orig={}; for _,p in ipairs(ps) do orig[p]={CFrame=p.CFrame,Size=p.Size} end
		for _,p in ipairs(ps) do local o=orig[p]; p.Size=o.Size*f; p.CFrame=CFrame.new(pivot+(o.CFrame.Position-pivot)*f)*o.CFrame.Rotation end
	end

	local function mkB(text,x,y,w,h,cb,prim)
		local b=G("TextButton",{Size=UDim2.new(0,w,0,h or 30),Position=UDim2.new(0,x,0,y),BackgroundColor3=prim and C.white or C.bg3,Text=text,TextColor3=prim and C.bg0 or C.off,Font=Enum.Font.GothamBold,TextSize=10,BorderSizePixel=0,AutoButtonColor=false,ZIndex=6},mp)
