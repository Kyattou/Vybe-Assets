	mkB("2×",P+54,250,50,24,function() MOVE_STEP=math.min(64,MOVE_STEP*2);refreshSpd() end)
	mkB("RST",P+108,250,50,24,function() MOVE_STEP=2;ROT_STEP=15;refreshSpd() end)

	L("SCALE",284,9,C.dim,true)
	local svs={{0.9,"90%"},{0.95,"95%"},{1.05,"105%"},{1.1,"110%"},{1.25,"125%"},{1.5,"150%"},{1.75,"175%"},{2,"200%"}}
	for si,sv in ipairs(svs) do
		local row=math.floor((si-1)/4); local col=(si-1)%4
		mkB(sv[2],P+col*58,300+row*32,54,28,function() scaleAll(sv[1]) end)
	end

	-- confirm/delete
	local cBtn=mkB("✓  CONFIRM",P,432,120,40,nil,true); cBtn.TextSize=12; cBtn.Font=Enum.Font.GothamBlack
	cBtn.MouseButton1Click:Connect(function()
		activeModel=nil; moverGui:Destroy(); moverGui=nil
		setStatus("Stadium confirmed & locked!",C.green); win.Visible=true
	end)
	local dBtn=G("TextButton",{Size=UDim2.new(0,120,0,40),Position=UDim2.new(0,P+128,0,432),BackgroundColor3=C.rbg,Text="✕  DELETE",TextColor3=C.red,Font=Enum.Font.GothamBold,TextSize=12,BorderSizePixel=0,AutoButtonColor=false,ZIndex=6},mp)
	corner(5,dBtn); stroke(dBtn,Color3.fromRGB(50,14,14),1)
