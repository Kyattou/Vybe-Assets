local function stroke(p, col, t) local s=Instance.new("UIStroke",p); s.Color=col or C.bdr; s.Thickness=t or 1; return s end
local function padding(p, l, t, r, b) local u=Instance.new("UIPadding",p); u.PaddingLeft=UDim.new(0,l or 0); u.PaddingTop=UDim.new(0,t or 0); u.PaddingRight=UDim.new(0,r or 0); u.PaddingBottom=UDim.new(0,b or 0) end
