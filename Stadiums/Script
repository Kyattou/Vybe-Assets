			draggingEl=true; dOX=inp.Position.X-ref.AbsolutePosition.X; dOY=inp.Position.Y-ref.AbsolutePosition.Y
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if draggingEl and inp.UserInputType==Enum.UserInputType.MouseMovement then
