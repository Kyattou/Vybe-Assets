local function normTexId(raw)
	if not raw or raw=="" then return nil end
	if raw:match("^rbxassetid://%d+$") then return raw end
	local n=raw:match("rbxassetid://(%d+)") or raw:match("[?&]id=(%d+)") or raw:match("^%s*(%d+)%s*$")
	return n and ("rbxassetid://"..n) or nil
end

local function swapTex(acc, texId)
	local h=acc:FindFirstChild("Handle"); if not h then return false end
	local nh=h:Clone()
	local ok=pcall(function()
		if nh:IsA("MeshPart") then nh.TextureID=texId
		else local sm=nh:FindFirstChildOfClass("SpecialMesh"); if sm then sm.TextureId=texId end end
	end)
	if not ok then nh:Destroy(); return false end
	local cf=h.CFrame; nh.Anchored=false; h:Destroy(); nh.Parent=acc; nh.CFrame=cf
	return true
end

local function activeGrp() return activeGroupIdx and groups[activeGroupIdx] or nil end

local function pushChar(rp)
	local char=rp.Character; if not char then return end
	task.spawn(function()
		task.wait(0.12); local ag=activeGrp(); if not ag then return end
		for _,ch in ipairs(char:GetChildren()) do
			if ch:IsA("Accessory") and ch.Name:sub(1,7)=="JERSEY_" then
				local tex=ag.slots[ch.Name]
				if tex then
					local lk=rp.UserId..ch.Name
					if not cooldowns[lk] then
						cooldowns[lk]=true; task.delay(0.5,function() cooldowns[lk]=nil end)
						pcall(function() ContentProvider:PreloadAsync({tex}) end)
						swapTex(ch,tex)
					end
				end
			end
		end
	end)
end

local function pushAll()
	local ag=activeGrp(); if not ag then return end
	for _,u in ipairs(ag.players) do
		for _,rp in ipairs(Players:GetPlayers()) do if rp.Name:lower()==u:lower() then pushChar(rp);break end end
	end
end

local function activateGroup(idx)
	for _,cs in pairs(charConns) do for _,c in ipairs(cs) do pcall(function() c:Disconnect() end) end end
	for _,cs in pairs(watchConns) do for _,c in ipairs(cs) do pcall(function() c:Disconnect() end) end end
	charConns={}; watchConns={}; activeGroupIdx=idx
	local ag=activeGrp(); if not ag then return end
	for _,u in ipairs(ag.players) do
		for _,rp in ipairs(Players:GetPlayers()) do
			if rp.Name:lower()==u:lower() then
				local function onC(char)
					task.wait(0.18)
					char.ChildAdded:Connect(function(ch)
						if ch:IsA("Accessory") and ch.Name:sub(1,7)=="JERSEY_" then
							task.wait(0.14); local tex=ag.slots[ch.Name]
							if tex then pcall(function() ContentProvider:PreloadAsync({tex}) end); swapTex(ch,tex) end
						end
					end)
					pushChar(rp)
				end
				if rp.Character then onC(rp.Character) end
				if not charConns[rp.UserId] then charConns[rp.UserId]={} end
				table.insert(charConns[rp.UserId],rp.CharacterAdded:Connect(onC)); break
			end
		end
	end
	pushAll()
end

