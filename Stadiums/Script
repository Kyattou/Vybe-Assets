local function splitChunks(j) jsonChunks={}; local cs=math.min(CHUNK_SIZE,200000)
	for i=1,#j,cs do table.insert(jsonChunks,j:sub(i,math.min(i+cs-1,#j))) end
end
local function reassemble() fullJson=table.concat(jsonChunks,""); return fullJson end
local function updateSDViewer()
	if #jsonChunks==0 then return end
	sdDataTb.Text=jsonChunks[currentChunk]
	sdDataLbl.Text=string.format("JSON  ·  %d/%d chunks  ·  %.1fKB",currentChunk,#jsonChunks,#jsonChunks[currentChunk]/1024)
	sdScroll.CanvasSize=UDim2.new(0,0,0,sdDataTb.TextBounds.Y+24)
end

if sdExportBtn then sdExportBtn.MouseButton1Click:Connect(function()
