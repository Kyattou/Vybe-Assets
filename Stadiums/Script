	startLoad("Exporting '"..mn.."'..."); task.wait(0.1)
	local ok,res=pcall(function() return exportRemote:InvokeServer(mn) end); stopLoad()
	if not ok then setStatus("Export error: "..tostring(res),C.red); return end
	currentData=res; fullJson=res; splitChunks(res); currentChunk=1; updateSDViewer()
	setStatus(string.format("Exported '%s' · %.1fKB",mn,#res/1024),C.green)
end) end

if sdUploadBtn then sdUploadBtn.MouseButton1Click:Connect(function()
	if not currentData then setStatus("Export first",C.red); return end
	local sid=sdIdInput and sdIdInput.Text or ""; if sid=="" then setStatus("Enter a save ID",C.red); return end
	startLoad("Uploading...",true); task.wait(0.1)
	local ud=#jsonChunks>0 and reassemble() or currentData
	local ok,res=pcall(function() return uploadRemote:InvokeServer(ud,sid,{uploadedBy=player.Name}) end)
	if ok and res and res.success then updProg(1,1); task.wait(0.3); stopLoad(); setStatus("Uploaded · ID: "..sid,C.green)
	else stopLoad(); setStatus("Upload failed",C.red) end
end) end

if sdDownloadBtn then sdDownloadBtn.MouseButton1Click:Connect(function()
	local sid=sdIdInput and sdIdInput.Text or ""; if sid=="" then setStatus("Enter a save ID",C.red); return end
	startLoad("Downloading..."); task.wait(0.1)
