	else setStatus("Download failed",C.red) end
end) end

sdPasteBtn.MouseButton1Click:Connect(function()
	local jc=""
	pcall(function() local cl=UserInputService:GetTextFromClipboard(); if cl and #cl>2 then local t=cl:match("^%s*(.-)%s*$"); if t:sub(1,1)=="[" or t:sub(1,1)=="{" then jc=t end end end)
	if jc=="" then local bt=(sdDataTb.Text or ""):match("^%s*(.-)%s*$"); if #bt>2 and (bt:sub(1,1)=="[" or bt:sub(1,1)=="{") then jc=bt end end
	if jc=="" then setStatus("No JSON found — copy from website first",C.red); return end
	if not pcall(function() HttpService:JSONDecode(jc) end) then setStatus("Invalid JSON",C.red); return end
	currentData=jc; fullJson=jc; splitChunks(jc); currentChunk=1; updateSDViewer()
	setStatus(string.format("JSON loaded · %.1fKB · Ready!",#jc/1024),C.green)
end)

sdImportBtn.MouseButton1Click:Connect(function()
	if not currentData then setStatus("No data — paste JSON first",C.red); return end
	startLoad("Parsing...",true); task.wait(0.1)
	local jstr=#jsonChunks>0 and reassemble() or currentData
	local ok,pData=pcall(function() return HttpService:JSONDecode(jstr) end)
	if not ok or type(pData)~="table" then stopLoad(); setStatus("Invalid JSON",C.red); return end
	loTitle.Text="Creating parts..."; task.wait(0.1)
	local model=Instance.new("Model"); model.Name="VybeStadium"; model.Parent=workspace
	local subs={}; local partLookup={}; local created=0
	for i,pd2 in ipairs(pData) do
		pcall(function()
			local part,pName,fp=buildPartFromData(pd2)
			if not subs[pName] then local s=Instance.new("Model"); s.Name=pName; s.Parent=model; subs[pName]=s end
			part.Parent=subs[pName]; if fp~="" then partLookup[fp]=part end
		end)
		created=created+1; if created%10==0 then updProg(created,#pData); task.wait() end
	end
	loTitle.Text="Auto-fitting..."; task.wait(0.1)
	local allP={}
	for _,o in ipairs(model:GetDescendants()) do if o:IsA("BasePart") then if o.Transparency>=0.8 then o.CanCollide=false;o.CanTouch=false;o.CanQuery=false;o.Massless=true end; table.insert(allP,o) end end
	local resized=false
	if #allP>0 then resized=autoFit(allP,fieldGeo(),model) end
	local bst,bv=nil,0
	for _,o in ipairs(model:GetDescendants()) do if o:IsA("BasePart") and o.Transparency<0.5 then local v=o.Size.X*o.Size.Y*o.Size.Z; if v>bv then bv=v;bst=o end end end
	if bst then model.PrimaryPart=bst end
	stopLoad(); setStatus(string.format("Imported · %d parts%s",created,resized and " · Auto-fitted" or ""),C.green)
	win.Visible=false; launchMover(model)
end)


