		if activeModel and activeModel.Parent then activeModel:Destroy() end
		activeModel=nil; moverGui:Destroy(); moverGui=nil
		setStatus("Stadium deleted"); win.Visible=true
	end)

	local kc=UserInputService.InputBegan:Connect(function(inp,gp)
		if gp or not activeModel then return end
		if inp.UserInputType~=Enum.UserInputType.Keyboard then return end
		local k=inp.KeyCode
		if k==Enum.KeyCode.W then moveAll(Vector3.new(0,0,-MOVE_STEP))
		elseif k==Enum.KeyCode.S then moveAll(Vector3.new(0,0,MOVE_STEP))
		elseif k==Enum.KeyCode.A then moveAll(Vector3.new(-MOVE_STEP,0,0))
		elseif k==Enum.KeyCode.D then moveAll(Vector3.new(MOVE_STEP,0,0))
		elseif k==Enum.KeyCode.R then moveAll(Vector3.new(0,MOVE_STEP,0))
		elseif k==Enum.KeyCode.F then moveAll(Vector3.new(0,-MOVE_STEP,0))
		elseif k==Enum.KeyCode.Q then rotAll(-ROT_STEP)
		elseif k==Enum.KeyCode.E then rotAll(ROT_STEP) end
	end)
	moverGui.Destroying:Connect(function() kc:Disconnect() end)
end

-- Shared import function
local function doImportAsset(rawId)
	local id=tostring(rawId):match("(%d+)")
	if not id then setStatus("Invalid Asset ID",C.red); return end
	id=tonumber(id)
	startLoad("Loading Asset "..id.."..."); setStatus("Fetching asset "..id.."...",C.dim); task.wait(0.1)
	local ok,objs=pcall(function() return game:GetObjects("rbxassetid://"..id) end)
	if not ok or not objs or #objs==0 then stopLoad(); setStatus("Asset load failed — check the ID",C.red); return end
	local model=Instance.new("Model"); model.Name="VybeAsset_"..id
	for _,o in ipairs(objs) do o.Parent=model end
	local parts={}
	for _,o in ipairs(model:GetDescendants()) do
		if o:IsA("BasePart") then
			if o.Transparency>=0.8 then o.CanCollide=false;o.CanTouch=false;o.CanQuery=false;o.Massless=true; pcall(function() o.CollisionGroup="VybeNC" end) end
			table.insert(parts,o)
		end
	end
	if #parts==0 then model:Destroy(); stopLoad(); setStatus("Asset has no BaseParts",C.red); return end
	model.Parent=workspace
	loTitle.Text="Auto-fitting to field..."; task.wait(0.1)
	local geo=fieldGeo(); local resized=autoFit(parts,geo,model)
	local bst,bv=nil,0
	for _,o in ipairs(model:GetDescendants()) do if o:IsA("BasePart") and o.Transparency<0.5 then local v=o.Size.X*o.Size.Y*o.Size.Z; if v>bv then bv=v;bst=o end end end
	if bst then pcall(function() model.PrimaryPart=bst end) end
	stopLoad()
	setStatus(string.format("Asset %d imported · %d parts%s",id,#parts,resized and " · Auto-fitted" or ""),C.green)
	win.Visible=false; launchMover(model)
end

