		b.MouseEnter:Connect(function() tw(b,{BackgroundColor3=prim and Color3.fromRGB(220,220,220) or C.hover},TF) end)
		b.MouseLeave:Connect(function() tw(b,{BackgroundColor3=prim and C.white or C.bg3},TF) end)
		b.MouseButton1Click:Connect(cb); return b
	end

	local P=12; local BW=70

	L("TRANSLATE",60,9,C.dim,true)
	mkB("▲ FWD",    P,     76,BW,28,function() moveAll(Vector3.new(0,0,-MOVE_STEP)) end)
	mkB("↑ UP",     P+BW+6,76,BW,28,function() moveAll(Vector3.new(0,MOVE_STEP,0)) end)
